EXPO_PUBLIC_API_URL=http://localhost:4000



# Google OAuth Web Client ID — must match backend GOOGLE_CLIENT_ID.

# Create in Google Cloud Console (OAuth 2.0 Client ID → Web application).

# Required for "Continue with Google" on Login and Register screens.

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Legal pages — deployed memora-legal site URLs (no trailing slash on base).

EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain/privacy

EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://your-domain/terms

