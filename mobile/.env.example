# Base URL only — include http:// or https://, no trailing slash, no /api/v1 suffix.
# Local dev (default):
EXPO_PUBLIC_API_URL=http://localhost:4000

# Production API (EAS preview/production builds use eas.json; optional for local testing):
# EXPO_PUBLIC_API_URL=https://memora.jkssbfy.in



# Google OAuth Web Client ID — must match backend GOOGLE_CLIENT_ID.
# Create in Google Cloud Console (OAuth 2.0 Client ID → Web application).
# Required for "Continue with Google" on Login and Register screens.
# See docs/google-auth-setup.md for Play Store setup.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Google OAuth Android Client ID — must match backend GOOGLE_ANDROID_CLIENT_ID.
# Create in Google Cloud Console (OAuth 2.0 Client ID → Android).
# Required for EAS preview APK, internal testing, and Play Store production builds.
# Package name: com.memora.mobile — register debug, EAS, and Play App Signing SHA-1 fingerprints.
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Legal pages — deployed memora-legal site URLs (no trailing slash on base).

EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain/privacy

EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://your-domain/terms

