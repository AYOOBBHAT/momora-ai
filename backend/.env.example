NODE_ENV=development
PORT=4000

# Health endpoints (GET /health, GET /system/chat-health).
# Default: enabled when NODE_ENV is not production, disabled in production.
# When enabled, requires an authenticated admin Bearer token; unauthorized requests receive 404.
HEALTH_ENDPOINTS_ENABLED=true
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/memora?retryWrites=true&w=majority
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# Comma-separated browser origins allowed by CORS (credentials enabled).
# Development default (when unset): localhost:3000, :19006, :8081 for web + Expo web.
# Native Expo/APK clients do not send Origin and are not blocked by CORS.
# Production (Railway): HTTPS origins only — never use '*'.
# Example: CORS_ORIGINS=https://your-app.vercel.app,https://your-legal-site.vercel.app
CORS_ORIGINS=https://localhost:3000
# Legacy single origin (optional if CORS_ORIGINS is set):
# CORS_ORIGIN=http://localhost:3000
BCRYPT_SALT_ROUNDS=12

# Resend — required for password reset OTP emails.
# Create an API key at https://resend.com/api-keys and verify your sending domain.
RESEND_API_KEY=
EMAIL_FROM=Memora <noreply@yourdomain.com>
PASSWORD_RESET_OTP_EXPIRES_MINUTES=10
PASSWORD_RESET_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_MAX_ATTEMPTS=5

# Google OAuth Web Client ID — required for POST /auth/google (Sign in with Google).
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# See docs/google-auth-setup.md for full Play Store setup.
GOOGLE_CLIENT_ID=

# Google OAuth Android Client ID — optional but required for Play Store / EAS Android builds.
# ID tokens from Android standalone builds use this client as the audience (aud claim).
# Must match mobile EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID. Keep GOOGLE_CLIENT_ID (Web) set.
GOOGLE_ANDROID_CLIENT_ID=

# Google AI Studio API key — required for document embeddings and semantic search.
# Create one at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Gemini embedding model (default: gemini-embedding-001, 768-dimensional vectors via outputDimensionality).
# text-embedding-004 was retired Jan 2026 — use gemini-embedding-001 instead.
# See backend/src/services/embedding.service.ts (EMBEDDING_DIMENSIONS).
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Groq API key — required for RAG chat answer generation.
# Create one at https://console.groq.com/keys
GROQ_API_KEY=

# Groq chat model for RAG answers (default: qwen/qwen3-32b).
GROQ_MODEL=qwen/qwen3-32b
# MongoDB Atlas Vector Search index name (see README for index setup).
VECTOR_SEARCH_INDEX_NAME=document_embedding_index
